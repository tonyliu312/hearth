# AI-MONITOR · environment overrides
# Copy to .env and edit. docker-compose will pick it up automatically.

# Atlas hostname/IP — used in the Prometheus external URL
ATLAS_HOST=192.168.1.20

# Prometheus retention
PROM_RETENTION=7d

# LiteLLM upstream (already running on Atlas:4000 per your setup)
LITELLM_URL=http://192.168.1.20:4000
LITELLM_MASTER_KEY=sk-1234

# CORS — restrict to your monitor host in prod
CORS_ORIGINS=*

# Spark node IPs — referenced by prometheus/prometheus.yml via env_file
SPARK_01=192.168.1.151
SPARK_02=192.168.1.156
SPARK_03=192.168.1.188
SPARK_04=192.168.1.189
